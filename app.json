{
  "expo": {
    "name": "MatchDay",
    "slug": "matchday-v3",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "matchday",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "react-native-maps"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
